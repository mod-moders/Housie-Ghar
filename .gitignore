# ─────────────────────────────────────────────────────────────────────
# Repo root is ignored ENTIRELY except the HG/ application and this file.
# HG/ is re-included below; the recursive rules after it still filter
# HG/'s own internals (deps, build output, secrets, OS cruft).
# Anything else dropped at the repo root (docs, prototypes, design assets,
# screenshots, unrelated projects) stays out of git.
# ─────────────────────────────────────────────────────────────────────
/*
!/.gitignore
!/HG/

# ─── Everything below filters files *inside* HG/ ───

# Dependencies
node_modules/
.pnp
.pnp.js

# Env & secrets
.env
.env.*
!.env.example
*.pem
private.pem
public.pem
*.key

# Build output
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Caches / tooling
.turbo/
.cache/
coverage/
.eslintcache

# Backups & data dumps
HG/backups/
*.sql.gz
*.dump

# Claude Code local config
.claude/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
._*
Screenshot*.png

# Large binaries (should never be in the repo)
*.dmg
*.pkg
*.zip
*.crdownload

# Compiled shared types (build artifacts)
HG/shared/types/*.js
HG/shared/types/*.js.map
HG/shared/types/*.d.ts
HG/shared/types/*.d.ts.map

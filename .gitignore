# ─────────────────────────────────────────────────────────────────────
# Repo root is ignored ENTIRELY except the HG/ application and this file.
# HG/ is re-included below; the recursive rules after it still filter
# HG/'s own internals (deps, build output, secrets, OS cruft).
# Anything else dropped at the repo root (docs, prototypes, design assets,
# screenshots, unrelated projects) stays out of git.
# ─────────────────────────────────────────────────────────────────────
/*
!/.gitignore
!/CLAUDE.md
!/HG/
!/.github/
!/manual.md

# ─── Everything below filters files *inside* HG/ ───

# Dependencies
node_modules/
.pnp
.pnp.js

# Env & secrets
.env
.env.*
!.env.example
*.pem
private.pem
public.pem
*.key

# Build output
.next/
out/
dist/
build/
*.tsbuildinfo
next-env.d.ts

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Caches / tooling
.turbo/
.cache/
coverage/
.eslintcache

# Backups & data dumps
HG/backups/
*.sql.gz
*.dump

# Claude Code local config
.claude/

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
._*
Screenshot*.png

# Large binaries (should never be in the repo)
*.dmg
*.pkg
*.zip
*.crdownload

# ─── Reference material, design assets, extra secrets (defense-in-depth) ───
# The repo root is already fully ignored by /* at the top; these patterns also
# catch anything of this kind that ever lands *inside* HG/ or .github/.
# Design source files
*.psd
*.sketch
*.fig
*.xd
*.ai
# Reference PDFs / exports
*.pdf
# Extra secret & certificate formats (beyond *.pem / *.key above)
*.crt
*.cer
*.p12
*.pfx
*.keystore
id_rsa
id_rsa.pub
# Screenshots (any case, png/jpg)
[Ss]creenshot*.png
[Ss]creenshot*.jpg
[Ss]creenshot*.jpeg
# Unused Next.js starter SVGs (app uses inline Icon.tsx, never public/*.svg)
HG/frontend/public/*.svg

# Compiled shared types (build artifacts)
HG/shared/types/*.js
HG/shared/types/*.js.map
HG/shared/types/*.d.ts
HG/shared/types/*.d.ts.map
.gstack/
